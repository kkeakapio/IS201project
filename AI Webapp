        let ballSpeed = INITIAL_SPEED;

        let playerX = (canvas.width - PADDLE_WIDTH) / 2;
        let cpuX = (canvas.width - PADDLE_WIDTH) / 2;
        
        let score = 0;
        let highScore = localStorage.getItem('pongHighScore') || 0;
        highScoreElement.innerText = `BEST: ${highScore}`;

        let leftPressed = false;
        let rightPressed = false;

        // Event Listeners
        document.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowLeft') leftPressed = true;
            if (e.key === 'ArrowRight') rightPressed = true;
        });

        document.addEventListener('keyup', (e) => {
            if (e.key === 'ArrowLeft') leftPressed = false;
            if (e.key === 'ArrowRight') rightPressed = false;
        });

        function resetBall() {
            if (score > highScore) {
                highScore = score;
                localStorage.setItem('pongHighScore', highScore);
                highScoreElement.innerText = `BEST: ${highScore}`;
            }
            
            score = 0;
            scoreElement.innerText = score;
            ballX = canvas.width / 2;
            ballY = canvas.height / 2;
            ballSpeed = INITIAL_SPEED;
            ballVX = INITIAL_SPEED * (Math.random() > 0.5 ? 1 : -1);
            ballVY = INITIAL_SPEED;
        }

        function update() {
            // Move Player
            if (leftPressed && playerX > 0) playerX -= 7;
            if (rightPressed && playerX < canvas.width - PADDLE_WIDTH) playerX += 7;

            // Move CPU (Perfect tracking as requested)
            // Centering the paddle on the ball
            cpuX = ballX - PADDLE_WIDTH / 2;
            // Keep CPU in bounds
            if (cpuX < 0) cpuX = 0;
            if (cpuX > canvas.width - PADDLE_WIDTH) cpuX = canvas.width - PADDLE_WIDTH;

            // Move Ball
            ballX += ballVX;
            ballY += ballVY;

            // Wall Collisions (Left/Right)
            if (ballX <= 0 || ballX + BALL_SIZE >= canvas.width) {
                ballVX *= -1;
            }

            // CPU Paddle Collision (Top)
            if (ballY <= PADDLE_HEIGHT) {
                if (ballX > cpuX && ballX < cpuX + PADDLE_WIDTH) {
                    ballVY = Math.abs(ballVY); // Ensure it goes down
                    increaseSpeed();
                }
            }

            // Player Paddle Collision (Bottom)
            if (ballY + BALL_SIZE >= canvas.height - PADDLE_HEIGHT) {
                if (ballX > playerX && ballX < playerX + PADDLE_WIDTH) {
                    ballVY = -Math.abs(ballVY); // Ensure it goes up
                    score++;
                    scoreElement.innerText = score;
                    increaseSpeed();
                } else {
                    resetBall(); // Game over
                }
            }
        }

